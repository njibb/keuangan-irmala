datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum TransactionType {
  IN
  OUT
}

// Tambahkan Enum untuk Role Pengurus
enum UserRole {
  BENDAHARA
  KETUA
  PENGAWAS
}

model Transaction {
  id          String          @id @default(cuid())
  date        DateTime
  description String
  type        TransactionType
  amount      Float
  category    String
  receiptUrl  String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@map("transactions")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String   // Password akan di-hash (misal pakai bcrypt)
  role      UserRole @default(BENDAHARA) // Menggunakan Enum UserRole
  createdAt DateTime @default(now())

  @@map("users")
} 